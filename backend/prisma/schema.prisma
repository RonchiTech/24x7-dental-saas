generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  viewerStates ViewerState[]
}

model ViewerState {
  id               String        @id @default(cuid())
  userId           String
  studyInstanceUID String
  stateJson        Json
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id])
  measurements     Measurement[]

  @@unique([userId, studyInstanceUID])
}

model Measurement {
  id            String      @id @default(cuid())
  viewerStateId String
  tooth         String
  type          String
  label         String
  value         Float
  unit          String
  createdAt     DateTime    @default(now())
  viewerState   ViewerState @relation(fields: [viewerStateId], references: [id])
}
